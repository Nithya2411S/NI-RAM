---
/**
 * Layout.astro
 * Single Responsibility: Base HTML shell. Imports styles. Renders stars layer.
 */
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'NIRAM — Vedic Astrology' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="NIRAM — Vedic birth chart generator. Lahiri Ayanamsa, True Nodes, Whole Sign houses." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="stars" aria-hidden="true"></div>
    <slot />
  </body>
</html>
